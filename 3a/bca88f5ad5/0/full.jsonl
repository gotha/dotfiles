ainer's PostgreSQL data dir is deliberately NOT managed here.\n603\t    # Docker creates the bind-mount source and the postgres image chowns it to its\n604\t    # own uid (e.g. 70 on Alpine); a tmpfiles rule would re-chown it to root on\n605\t    # every rebuild and break the database with \"permission denied\" on its files.\n606\t    systemd.tmpfiles.rules =\n607\t      optional anyJobWritesDownloads \"d '${cfg.downloadDir}' 0750 ${cfg.user} ${cfg.group} - -\";\n608\t\n609\t    systemd.services = {\n610\t      # One-shot schema migration; every other unit orders after it.\n611\t      luna-podcatcher-migrate = {\n612\t        description = \"luna-podcatcher database migrations\";\n613\t        after = dbDeps;\n614\t        requires = dbDeps;\n615\t        environment = baseEnv;\n616\t        serviceConfig =\n617\t          hardening\n618\t          // serviceCommon\n619\t          // {\n620\t            Type = \"oneshot\";\n621\t            RemainAfterExit = true;\n622\t            ExecStart = \"${cfg.package}/bin/podcatcher migrate\";\n623\t          };\n624\t      };\n625\t\n626\t      # Long-running web server. Requires PostgreSQL (when local) and the\n627\t      # successful completion of the migration step.\n628\t      luna-podcatcher-server = {\n629\t        description = \"luna-podcatcher web server\";\n630\t        wantedBy = [ \"multi-user.target\" ];\n631\t        after = [\n632\t          \"network-online.target\"\n633\t          \"luna-podcatcher-migrate.service\"\n634\t        ]\n635\t        ++ dbDeps;\n636\t        requires = [ \"luna-podcatcher-migrate.service\" ] ++ dbDeps;\n637\t        wants = [ \"network-online.target\" ];\n638\t        environment = baseEnv // {\n639\t          PORT = toString cfg.port;\n640\t        };\n641\t        serviceConfig =\n642\t          hardening\n643\t          // serviceCommon\n644\t          // {\n645\t            Type = \"simple\";\n646\t            ExecStart = \"${cfg.package}/bin/server\";\n647\t            Restart = \"on-failure\";\n648\t            RestartSec = 5;\n649\t          };\n650\t      };\n651\t    }\n652\t    // mapAttrs' mkJobService enabledJobs\n653\t    // optionalAttrs useContainer {\n654\t      # Generate the container's PostgreSQL password and the DATABASE_URL env\n655\t      # file the luna units read — once, then persisted under containerStateDir.\n656\t      luna-podcatcher-db-secret = {\n657\t        description = \"luna-podcatcher: generate dedicated database credentials\";\n658\t        wantedBy = [ \"multi-user.target\" ];\n659\t        path = [\n660\t          pkgs.openssl\n661\t          pkgs.coreutils\n662\t        ];\n663\t        serviceConfig = {\n664\t          Type = \"oneshot\";\n665\t          RemainAfterExit = true;\n666\t        };\n667\t        script = ''\n668\t          set -euo pipefail\n669\t          install -d -m 0750 ${containerStateDir}\n670\t          if [ ! -s ${containerPasswordFile} ]; then\n671\t            ( umask 077; openssl rand -hex 24 > ${containerPasswordFile} )\n672\t          fi\n673\t          pw=\"$(cat ${containerPasswordFile})\"\n674\t          tmp=\"$(mktemp ${containerStateDir}/db.env.XXXXXX)\"\n675\t          printf 'DATABASE_URL=REDACTED' \\\n676\t            '${dbcfg.user}' \"$pw\" ${toString dbcfg.container.port} '${dbcfg.name}' > \"$tmp\"\n677\t          chown root:${cfg.group} \"$tmp\"\n678\t          chmod 0640 \"$tmp\"\n679\t          mv -f \"$tmp\" ${containerEnvFile}\n680\t        '';\n681\t      };\n682\t\n683\t      # Order the oci-containers unit after the credential generator whose\n684\t      # password file it bind-mounts (merges with the generated unit).\n685\t      \"docker-luna-podcatcher-db\" = {\n686\t        after = [ \"luna-podcatcher-db-secret.service\" ];\n687\t        requires = [ \"luna-podcatcher-db-secret.service\" ];\n688\t      };\n689\t"}]},"uuid":"7a7d72bb-7a2f-401b-b7b1-d09184989152","timestamp":"2026-06-24T10:46:21.548Z","toolUseResult":{"type":"text","file":{"filePath":"/home/gotha/Projects/github.com/gotha/luna-podcatcher/nix/module.nix","content":"          ensureDBOwnership = true;\n        }\n      ];\n    };\n\n    # Dedicated, containerized PostgreSQL backend. Published only on the host's\n    # loopback (127.0.0.1) so it never competes with anything on a public\n    # interface; credentials come from the password file generated below.\n    virtualisation.docker.enable = mkIf useContainer (mkDefault true);\n\n    virtualisation.oci-containers = mkIf useContainer {\n      backend = \"docker\";\n      containers.luna-podcatcher-db = {\n        image = dbcfg.container.image;\n        ports = [ \"127.0.0.1:${toString dbcfg.container.port}:5432\" ];\n        volumes = [\n          \"${dbcfg.container.dataDir}:/var/lib/postgresql/data\"\n          \"${containerPasswordFile}:/run/secrets/postgres-password:ro\"\n        ];\n        environment = {\n          POSTGRES_USER = dbcfg.user;\n          POSTGRES_DB = dbcfg.name;\n          POSTGRES_PASSWORD_FILE = \"/run/secrets/postgres-password\";\n        };\n      };\n    };\n\n    users.users.${cfg.user} = {\n      isSystemUser = true;\n      group = cfg.group;\n      description = \"luna-podcatcher service user\";\n    };\n    users.groups.${cfg.group} = { };\n\n    # Admin CLI on the system PATH: `sudo podcatcher feeds add <url>`, etc.\n    environment.systemPackages = mkIf cfg.installCli [ adminCli ];\n\n    networking.firewall = mkIf cfg.openFirewall {\n      allowedTCPPorts = [ cfg.port ];\n    };\n\n    # Ensure the download directory exists before the jobs that write to it run.\n    # NOTE: the container's PostgreSQL data dir is deliberately NOT managed here.\n    # Docker creates the bind-mount source and the postgres image chowns it to its\n    # own uid (e.g. 70 on Alpine); a tmpfiles rule would re-chown it to root on\n    # every rebuild and break the database with \"permission denied\" on its files.\n    systemd.tmpfiles.rules =\n      optional anyJobWritesDownloads \"d '${cfg.downloadDir}' 0750 ${cfg.user} ${cfg.group} - -\";\n\n    systemd.services = {\n      # One-shot schema migration; every other unit orders after it.\n      luna-podcatcher-migrate = {\n        description = \"luna-podcatcher database migrations\";\n        after = dbDeps;\n        requires = dbDeps;\n        environment = baseEnv;\n        serviceConfig =\n          hardening\n          // serviceCommon\n          // {\n            Type = \"oneshot\";\n            RemainAfterExit = true;\n            ExecStart = \"${cfg.package}/bin/podcatcher migrate\";\n          };\n      };\n\n      # Long-running web server. Requires PostgreSQL (when local) and the\n      # successful completion of the migration step.\n      luna-podcatcher-server = {\n        description = \"luna-podcatcher web server\";\n        wantedBy = [ \"multi-user.target\" ];\n        after = [\n          \"network-online.target\"\n          \"luna-podcatcher-migrate.service\"\n        ]\n        ++ dbDeps;\n        requires = [ \"luna-podcatcher-migrate.service\" ] ++ dbDeps;\n        wants = [ \"network-online.target\" ];\n        environment = baseEnv // {\n          PORT = toString cfg.port;\n        };\n        serviceConfig =\n          hardening\n          // serviceCommon\n          // {\n            Type = \"simple\";\n            ExecStart = \"${cfg.package}/bin/server\";\n            Restart = \"on-failure\";\n            RestartSec = 5;\n          };\n      };\n    }\n    // mapAttrs' mkJobService enabledJobs\n    // optionalAttrs useContainer {\n      # Generate the container's PostgreSQL password and the DATABASE_URL env\n      # file the luna units read — once, then persisted under containerStateDir.\n      luna-podcatcher-db-secret = {\n        description = \"luna-podcatcher: generate dedicated database credentials\";\n        wantedBy = [ \"multi-user.target\" ];\n        path = [\n          pkgs.openssl\n          pkgs.coreutils\n        ];\n        serviceConfig = {\n          Type = \"oneshot\";\n          RemainAfterExit = true;\n        };\n        script = ''\n          set -euo pipefail\n          install -d -m 0750 ${containerStateDir}\n          if [ ! -s ${containerPasswordFile} ]; then\n            ( umask 077; openssl rand -hex 24 > ${containerPasswordFile} )\n          fi\n          pw=\"$(cat ${containerPasswordFile})\"\n          tmp=\"$(mktemp ${containerStateDir}/db.env.XXXXXX)\"\n          printf 'DATABASE_URL=REDACTED' \\\n            '${dbcfg.user}' \"$pw\" ${toString dbcfg.container.port} '${dbcfg.name}' > \"$tmp\"\n          chown root:${cfg.group} \"$tmp\"\n          chmod 0640 \"$tmp\"\n          mv -f \"$tmp\" ${containerEnvFile}\n        '';\n      };\n\n      # Order the oci-containers unit after the credential generator whose\n      # password file it bind-mounts (merges with the generated unit).\n      \"docker-luna-podcatcher-db\" = {\n        after = [ \"luna-podcatcher-db-secret.service\" ];\n        requires = [ \"luna-podcatcher-db-secret.service\" ];\n      };\n","numLines":130,"startLine":560,"totalLines":715}},"sourceToolAssistantUUID":"9ae6a2d8-cd61-4d00-ae94-9a13ae01b2f4","userType":"external","entrypoint":"cli","cwd":"/home/gotha/Projects/github.com/gotha/dotfiles","sessionId":"108e6e67-96cc-4dca-bc52-61b8eb2c1144","version":"2.1.175","gitBranch":"main"}
