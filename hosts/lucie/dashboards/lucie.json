      "targets": [{ "datasource": { "type": "grafana-postgresql-datasource", "uid": "timescaledb" }, "rawSql": "WITH top_procs AS (SELECT process_name FROM procstat WHERE host = 'lucie' AND time > NOW() - INTERVAL '5 minutes' AND process_name IS NOT NULL GROUP BY process_name ORDER BY MAX(cpu_time_user + cpu_time_system) DESC LIMIT 10) SELECT time, process_name as metric, memory_usage as value FROM procstat WHERE host = 'lucie' AND process_name IN (SELECT process_name FROM top_procs) AND $__timeFilter(time) ORDER BY time", "format": "table", "refId": "A" }],
